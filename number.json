export default async function handler(req, res) {
    // CORS enable
    res.setHeader('Access-Control-Allow-Origin', '*');
    res.setHeader('Access-Control-Allow-Methods', 'GET');
    
    // URL se number parameter lelo
    const { number } = req.query;
    
    // Agar number nahi diya
    if (!number) {
        return res.status(200).json({
            success: false,
            user: "@zyro_ooo",
            message: "Number chahiye bhai!",
            example: "https://your-api.vercel.app/number?number=9693615642",
            help: "API usage guide ke liye ?help use karo"
        });
    }
    
    // Help option
    if (number === "help" || number === "?help") {
        return res.status(200).json({
            success: true,
            user: "@zyro_ooo",
            channel: "@ajaaobkl",
            message: "API Usage Guide",
            commands: {
                basic: "/number?number=YOUR_NUMBER",
                example: "/number?number=9876543210",
                features: [
                    "Get caller name",
                    "Alternative mobile numbers",
                    "Address information",
                    "Aadhaar details",
                    "Circle/Operator info",
                    "Father's name"
                ]
            },
            sources: ["Truecaller", "Google", "Internal Database", "Telegram Logs", "WhatsApp Groups"],
            total_sources: 5
        });
    }
    
    try {
        // Validate phone number (Indian)
        const phoneRegex = /^[6-9]\d{9}$/;
        if (!phoneRegex.test(number)) {
            return res.status(200).json({
                success: false,
                user: "@zyro_ooo",
                channel: "@ajaaobkl",
                message: "Invalid Indian mobile number!",
                error: "Number must start with 6,7,8,9 and be 10 digits long"
            });
        }
        
        // YAHAN PE APNA DATA SOURCE LAGAO
        // Option 1: Mock Data (Demo ke liye)
        const mockData = generateMockData(number);
        
        // Option 2: Agar kisi real API se data lena hai (comment hatao)
        /*
        const originalUrl = `https://all-number-info-rajan-eta.vercel.app/api?number=${number}`;
        const response = await fetch(originalUrl);
        const data = await response.json();
        */
        
        // Unique records store karne ke liye
        const records = [];
        const seenIds = new Set();
        
        // Stats for different sources
        const sourceStats = {
            source_1: 0,
            source_2: 0,
            source_5: 0,
            total_processed: 0
        };
        
        // Mock Data Generator (Replace with real API call)
        function generateMockData(num) {
            const names = ["Rajesh Kumar", "Priya Sharma", "Amit Patel", "Neha Singh", "Vikram Yadav"];
            const cities = ["Mumbai", "Delhi", "Bangalore", "Chennai", "Kolkata"];
            const operators = ["Jio", "Airtel", "Vi", "BSNL"];
            
            const randomIndex = Math.floor(Math.random() * names.length);
            const mockAadhaar = Math.random().toString().slice(2, 14);
            
            return {
                results: {
                    source_1: {
                        data: {
                            response: {
                                data: [{
                                    name: names[randomIndex],
                                    num: num,
                                    alt: `98${Math.floor(Math.random() * 10000000)}`,
                                    aadhar: mockAadhaar,
                                    address: `${Math.floor(Math.random() * 100)} ${cities[Math.floor(Math.random() * cities.length)]}`,
                                    circle: operators[Math.floor(Math.random() * operators.length)],
                                    fname: `Mr. ${names[randomIndex].split(' ')[0]} Sr.`
                                }]
                            }
                        }
                    },
                    source_2: {
                        data: {
                            data: [{
                                id: Math.floor(Math.random() * 10000),
                                NAME: names[randomIndex],
                                MOBILE: num,
                                ALTERNATE: `99${Math.floor(Math.random() * 10000000)}`,
                                AADHAAR_NO: mockAadhaar,
                                ADDRESS: `${cities[Math.floor(Math.random() * cities.length)]}, India`,
                                OPERATOR: operators[Math.floor(Math.random() * operators.length)],
                                FATHER_NAME: `Sh. ${names[randomIndex].split(' ')[0]}`
                            }]
                        }
                    }
                }
            };
        }
        
        // Source 1 se data lo
        const source1Data = mockData?.results?.source_1?.data?.response?.data;
        if (source1Data && Array.isArray(source1Data)) {
            for (const item of source1Data) {
                const uniqueId = item.aadhar || item.num;
                if (!seenIds.has(uniqueId) && item.name) {
                    seenIds.add(uniqueId);
                    records.push({
                        name: item.name,
                        mobile: item.num,
                        alt_mobile: item.alt || null,
                        aadhaar: item.aadhar || null,
                        address: item.address ? item.address.substring(0, 150) : null,
                        circle: item.circle || null,
                        father_name: item.fname || null,
                        source: "Truecaller Database",
                        confidence: "High"
                    });
                    sourceStats.source_1++;
                }
            }
        }
        
        // Source 2 se data lo
        const source2Data = mockData?.results?.source_2?.data?.data;
        if (source2Data && Array.isArray(source2Data)) {
            for (const item of source2Data) {
                const uniqueId = item.id || item.MOBILE;
                if (!seenIds.has(uniqueId) && item.NAME) {
                    seenIds.add(uniqueId);
                    records.push({
                        name: item.NAME,
                        mobile: item.MOBILE,
                        alt_mobile: item.ALTERNATE || null,
                        aadhaar: item.AADHAAR_NO || null,
                        address: item.ADDRESS || null,
                        circle: item.OPERATOR || null,
                        father_name: item.FATHER_NAME || null,
                        source: "Google Database",
                        confidence: "Medium"
                    });
                    sourceStats.source_2++;
                }
            }
        }
        
        sourceStats.total_processed = records.length;
        
        // Final Response
        return res.status(200).json({
            success: records.length > 0,
            user: "@zyro_ooo",
            channel: "@ajaaobkl",
            number: number,
            total_records: records.length,
            source_stats: sourceStats,
            data: records,
            message: records.length > 0 ? "Data fetched successfully" : "No data found for this number"
        });
        
    } catch (error) {
        console.error("API Error:", error);
        return res.status(200).json({
            success: false,
            user: "@zyro_ooo",
            channel: "@ajaaobkl",
            message: "Internal server error",
            error: error.message
        });
    }
}
